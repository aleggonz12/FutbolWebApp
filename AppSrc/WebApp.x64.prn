38378>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38381>>>        Case Begin
38381>>>            Case (NavigateData.eNavigateType = nfFromMain)
38383>>>                // If from main, this is a propbably a main file Select to Zoom.
38383>>>                Case Break
38384>>>
38384>>>            Case (NavigateData.eNavigateType = nfFromParent)
38387>>>                // If from parent, this is a constrained drill down.
38387>>>                Case Break
38388>>>
38388>>>            Case (NavigateData.eNavigateType = nfFromChild)
38391>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38391>>>                Case Break
38392>>>
38392>>>            Case Else // must be nfUndefined
38392>>>
38392>>>        Case End
38392>>>
38392>>>        Send SetActionButtons
38393>>>
38393>>>    End_Procedure
38394>>>
38394>>>End_Object 
