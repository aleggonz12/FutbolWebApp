37632>>>    Procedure SetActionButtons
37635>>>        tWebNavigateData NavigateData
37635>>>        tWebNavigateData NavigateData
37635>>>        Boolean bHasRecord
37635>>>        Handle hoDD
37635>>>
37635>>>        Get Server to hoDD
37636>>>        Get GetNavigateData to NavigateData
37637>>>        Get HasRecord of hoDD to bHasRecord
37638>>>
37638>>>        // let's hide all buttons and then Show the ones we want
37638>>>        WebSet pbRender of oEditBtn to False
37639>>>        WebSet pbRender of oSaveBtn to False
37640>>>        WebSet pbRender of oCancelChangesBtn to False
37641>>>        WebSet pbRender of oDeleteBtn to False
37642>>>
37642>>>        If (NavigateData.bReadOnly) Begin
37644>>>            WebSet pbRender of oEditBtn to True
37645>>>        End
37645>>>>
