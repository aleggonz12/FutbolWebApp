38350>>>    Procedure SetActionButtons
38353>>>        tWebNavigateData NavigateData
38353>>>        tWebNavigateData NavigateData
38353>>>        Boolean bHasRecord
38353>>>        Handle hoDD
38353>>>
38353>>>        Get Server to hoDD
38354>>>        Get GetNavigateData to NavigateData
38355>>>        Get HasRecord of hoDD to bHasRecord
38356>>>
38356>>>        // let's hide all buttons and then Show the ones we want
38356>>>        WebSet pbRender of oEditBtn to False
38357>>>        WebSet pbRender of oSaveBtn to False
38358>>>        WebSet pbRender of oCancelChangesBtn to False
38359>>>        WebSet pbRender of oDeleteBtn to False
38360>>>
38360>>>        If (NavigateData.bReadOnly) Begin
38362>>>            WebSet pbRender of oEditBtn to True
38363>>>        End
38363>>>>
38363>>>        Else Begin
38364>>>            WebSet pbRender of oSaveBtn to True
38365>>>            WebSet pbRender of oCancelChangesBtn to True
38366>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38367>>>        End
38367>>>>
38367>>>    End_Procedure
38368>>>
38368>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38371>>>        // Close after save
38371>>>        Send NavigateClose Self
38372>>>    End_Procedure
38373>>>
38373>>>    // this will close the view after a delete
38373>>>    Procedure OnViewDeleted Handle hoDDO
38376>>>        Send NavigateClose Self
38377>>>    End_Procedure
